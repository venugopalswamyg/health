# Example tfvars. Copy to environments/<env>.tfvars and adjust.
# NOTE: there is intentionally NO database password here. The DB password is
# generated by Terraform (random_password) and stored only in Key Vault and the
# encrypted remote state. Never commit secrets to git.

environment = "dev"
prefix      = "healthcare"
location    = "centralindia"

backend_resource_group  = "rg-terraform"
backend_storage_account = "tfstatehealthcare"
backend_container       = "tfstate"
backend_key             = "healthcare-azure-dev.tfstate"

resource_group_name  = "rg-healthcare-dev-tf"
vnet_name            = "healthcare-vnet-dev"
vnet_cidr            = "10.20.0.0/16"
private_subnet_cidr  = "10.20.1.0/24"
public_subnet_cidr   = "10.20.2.0/24"
postgres_subnet_cidr = "10.20.3.0/24"

acr_name = "healthcareacrdevtf"
acr_sku  = "Standard"

keyvault_name        = "hc-kv-dev-733833"
tenant_id            = "<AZURE_TENANT_ID>"
keyvault_secret_name = "database-url"

postgres_server_name   = "hc-pg-dev-733833"
postgres_admin_user    = "pgadmin"
postgres_sku           = "B_Standard_B1ms"
postgres_storage_gb    = 32
postgres_database_name = "healthcare"

aks_cluster_name = "aks-healthcare-dev"
aks_node_count   = 1
aks_node_vm_size = "Standard_D2s_v3"
aks_min_count    = 1
aks_max_count    = 3
